# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=""

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=""

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Never expose this key client-side — server use only
ANTHROPIC_API_KEY=""
# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL=""

# OAuth Providers (add as needed)
AUTH_GOOGLE_ID=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=""
NEXT_PUBLIC_APP_NAME="ZeroPlag"

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_FREE_RPM=10
RATE_LIMIT_PAID_RPM=100

# ─── Feature Flags ────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_PLAGIARISM=true
NEXT_PUBLIC_ENABLE_GRAMMAR=true
